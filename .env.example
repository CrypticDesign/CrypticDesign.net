# Enables local membership fixtures and internal sandbox APIs. Never enables live billing.
MEMBERSHIP_SANDBOX_ENABLED=false
# Local-only signing key for preview sessions. Use a unique value in .env.local.
MEMBERSHIP_SANDBOX_SECRET=

# Production selection: Supabase. Populate only after an approved project is provisioned.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
